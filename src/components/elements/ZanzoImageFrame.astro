---
import { Image } from "astro:assets";
const {className,src,alt,isPriority=false} = Astro.props;
import { ImagesIndex } from "../../assets/ImagesIndex";
---


<figure class={`${className} zanzo-frame`}>
    <Image src={src} alt={alt} class=`${className} zanzo-main` priority={isPriority} />
    <Image src={src} alt="" class=`${className} zanzo-ghost` aria-hidden="true" priority={isPriority} />
</figure>

<style lang="scss">
    .zanzo{
        &-frame{
            overflow:hidden;
            position: relative;
            > :global(img){
                width: 100%;
                height: 100%;
            }
        }
        &-ghost{
            position:absolute;
            inset:0;
            opacity: 0;
            transition: opacity 0.4s, transform 0.4s;
            pointer-events: none;
            
        }
    }

    :global([data-zanzomode="on"]) .zanzo-ghost{
        opacity: 0.7;
        transform: translateX(var(--zanzo-x));
    }
</style>