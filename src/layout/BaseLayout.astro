---
import "../assets/styles/index.scss";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import LoadingScreen from "../sections/LoadingScreen.astro";
import { ImagesIndex } from "../assets/ImagesIndex";

const {title=""} = Astro.props;
---


<html lang="ja">
    <head>
        <script is:inline>
            const saved = localStorage.getItem('zanzomode') ?? 'on';
            document.documentElement.dataset.zanzomode = saved;
        </script>

        <meta charset="utf-8"/>
        <link rel="icon" type="image/svg+xml" href={ImagesIndex.zanzo_logo.src} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
        <title>zanzo-{title}</title>
    </head>

    <body>
        <LoadingScreen/>
        <Header/>
        <main>
            <slot/>
        </main>
        <Footer/>
    </body>
</html>